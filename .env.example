# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://aya-baguio.vercel.app

# ── Payments (architecture placeholders — fill in when ready) ──
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
GCASH_MERCHANT_ID=
MAYA_MERCHANT_ID=

# PayMongo hosted payment link (AYA Founders & Creatives)
# Used as the "Pay Now" CTA on the confirmation page for paid tickets.
NEXT_PUBLIC_PAYMONGO_PAYMENT_LINK=https://paymongo.page/l/ayafounderscreatives

# ── Email Marketing (Resend) ──
# Get a free API key at https://resend.com — verify your sending domain
# (e.g. destinevents.biz) before going live.
RESEND_API_KEY=
EMAIL_FROM="As You Are Baguio <jenncastro@destinevents.biz>"

# Public logo URL used in email headers (square image, ~88x88px works well).
# Upload to Supabase Storage or /public and reference the public URL here.
NEXT_PUBLIC_COMPANY_LOGO_URL=https://aya-baguio.vercel.app/images/aya-logo.png

# Secret used to authorize the Vercel Cron call to /api/cron/abandoned-carts.
# Set the same value here and Vercel will send it automatically as
# `Authorization: Bearer <CRON_SECRET>` when calling cron routes.
CRON_SECRET=

# ── Admin ──
# Admin accounts are managed via Supabase Auth (Email/Password).
# Create your first admin user in the Supabase Dashboard > Authentication > Users
# then add their UUID to the `admin_users` table (see supabase/schema.sql).
